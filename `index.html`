<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BODAELMASRY ACADEMY - مدرسة بودا المصري</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Cairo', sans-serif;
        }
        
        body {
            background: #000;
            background-image: url('https://i.ibb.co/6gZQqZJ/boda-hacker-bg.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: #00ff00;
            min-height: 100vh;
        }
        
       .hidden { display: none!important; }
        
        /* شاشة الدخول */
        #login-screen {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
       .login-box {
            background: rgba(0, 0, 0, 0.9);
            border: 2px solid #00ff00;
            box-shadow: 0 0 40px #00ff00, inset 0 0 20px rgba(255,0,0,0.4);
            padding: 40px;
            width: 450px;
            text-align: center;
            animation: glitch 2s infinite;
        }
        
        @keyframes glitch {
            0%, 100% { box-shadow: 0 0 40px #00ff00, inset 0 0 20px rgba(255,0,0,0.4); }
            50% { box-shadow: 0 0 40px #ff0000, inset 0 0 20px rgba(0,255,0,0.4); }
        }
        
       .logo {
            font-size: 28px;
            font-weight: 900;
            margin-bottom: 30px;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
        }
        
       .logo span {
            display: inline-block;
            width: 35px;
            height: 35px;
            line-height: 35px;
            margin: 2px;
            background: #111;
            border: 1px solid #00ff00;
            animation: colorChange 3s infinite;
        }
        
        @keyframes colorChange {
            0%, 100% { color: #00ff00; border-color: #00ff00; text-shadow: 0 0 10px #00ff00; }
            33% { color: #ff0000; border-color: #ff0000; text-shadow: 0 0 10px #ff0000; }
            66% { color: #00ffff; border-color: #00ffff; text-shadow: 0 0 10px #00ffff; }
        }
        
        input {
            width: 100%;
            padding: 15px;
            margin: 10px 0;
            background: #111;
            border: 2px solid #00ff00;
            color: #00ff00;
            font-size: 18px;
            text-align: center;
        }
        
        input:focus {
            outline: none;
            box-shadow: 0 0 20px #00ff00;
        }
        
        button {
            width: 100%;
            padding: 15px;
            margin-top: 20px;
            background: #00ff00;
            color: #000;
            border: none;
            font-size: 20px;
            font-weight: 900;
            cursor: pointer;
            transition: 0.3s;
        }
        
        button:hover {
            background: #ff0000;
            color: #fff;
            box-shadow: 0 0 25px #ff0000;
            transform: scale(1.05);
        }
        
       .error {
            color: #ff0000;
            margin-top: 15px;
            display: none;
            text-shadow: 0 0 15px #ff0000;
            font-size: 18px;
        }
        
        /* الصفحة الرئيسية */
        #main-screen {
            padding: 20px;
            background: rgba(0,0,0,0.85);
            min-height: 100vh;
        }
        
       .header {
            text-align: center;
            padding: 20px;
            border-bottom: 3px solid #00ff00;
            margin-bottom: 30px;
        }
        
       .welcome-msg {
            font-size: 24px;
            color: #ff0000;
            text-shadow: 0 0 15px #ff0000;
            margin-bottom: 10px;
        }
        
       .sections-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        
       .section-card {
            background: rgba(17, 17, 17, 0.95);
            border: 2px solid #00ff00;
            padding: 20px;
            cursor: pointer;
            transition: 0.3s;
            position: relative;
            overflow: hidden;
        }
        
       .section-card:hover {
            box-shadow: 0 0 30px #00ff00;
            transform: translateY(-5px);
            border-color: #ff0000;
        }
        
       .section-card.locked {
            opacity: 0.5;
            cursor: not-allowed;
            border-color: #ff0000;
        }
        
       .section-card.locked::after {
            content: "🔒";
            position: absolute;
            top: 10px;
            left: 10px;
            font-size: 30px;
        }
        
       .section-img {
            width: 100%;
            height: 150px;
            background: #000;
            border: 1px solid #00ff00;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
        }
        
       .section-title {
            font-size: 20px;
            font-weight: 900;
            color: #00ff00;
            margin-bottom: 10px;
        }
        
        /* صفحة الدرس */
        #lesson-screen {
            padding: 20px;
            background: rgba(0,0,0,0.9);
            min-height: 100vh;
        }
        
       .lesson-content {
            background: #111;
            border: 2px solid #00ff00;
            padding: 30px;
            margin: 20px 0;
            line-height: 2;
            font-size: 18px;
        }
        
       .lesson-content h2 {
            color: #ff0000;
            margin-bottom: 20px;
            text-shadow: 0 0 10px #ff0000;
        }
        
       .lab-section {
            background: #000;
            border: 3px solid #ff0000;
            padding: 20px;
            margin: 30px 0;
        }
        
       .lab-title {
            color: #ff0000;
            font-size: 24px;
            text-align: center;
            margin-bottom: 20px;
            text-shadow: 0 0 15px #ff0000;
        }
        
       .lab-buttons {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin: 20px 0;
        }
        
       .lab-btn {
            padding: 20px;
            background: #111;
            border: 2px solid #00ff00;
            color: #00ff00;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
        }
        
       .lab-btn:hover {
            background: #00ff00;
            color: #000;
            box-shadow: 0 0 20px #00ff00;
        }
        
       .terminal {
            background: #000;
            border: 2px solid #00ff00;
            padding: 20px;
            margin: 20px 0;
            font-family: monospace;
            min-height: 200px;
        }
        
       .timer {
            color: #ff0000;
            font-size: 24px;
            text-align: center;
            margin: 15px 0;
            text-shadow: 0 0 15px #ff0000;
        }
        
        /* قسم التواصل */
       .contact-section {
            background: rgba(255,0,0,0.1);
            border: 3px solid #ff0000;
            padding: 30px;
            text-align: center;
            margin-top: 50px;
        }
        
       .contact-section h2 {
            color: #ff0000;
            margin-bottom: 20px;
        }
        
       .whatsapp-btn {
            background: #25D366;
            color: #fff;
            padding: 15px 40px;
            font-size: 20px;
            border: none;
            cursor: pointer;
            display: inline-block;
            text-decoration: none;
        }
        
        /* الشهادة */
        #certificate {
            background: #000;
            border: 5px solid #00ff00;
            padding: 50px;
            text-align: center;
            margin: 30px auto;
            max-width: 800px;
            box-shadow: 0 0 50px #00ff00;
        }
    </style>
</head>
<body>
    <!-- شاشة الدخول -->
    <div id="login-screen">
        <div class="login-box">
            <div class="logo" id="logo"></div>
            <input type="text" id="username" placeholder="اكتب اسمك" onclick="playClick()">
            <input type="password" id="password" placeholder="كلمة السر" onclick="playClick()">
            <button onclick="login()">دخــول 🔓</button>
            <div class="error" id="error">وصـول مـرفـوض.. حـاول مـرة أخـرى</div>
        </div>
    </div>

    <!-- الصفحة الرئيسية -->
    <div id="main-screen" class="hidden">
        <div class="header">
            <div class="welcome-msg" id="welcome-msg"></div>
            <h1>مدرسة بودا المصري للأمن السيبراني</h1>
            <p>اتعلم.. اخترق.. احمي</p>
        </div>
        
        <div class="sections-grid" id="sections-grid"></div>
        
        <!-- قسم التواصل -->
        <div class="contact-section">
            <h2>🔒 واقف معاك حاجة؟</h2>
            <p>دوس هنا كلم بودا المصري دايركت على الواتساب</p>
            <a href="https://wa.me/201122989039?text=سلام عليكم يا بودا.. أنا من المدرسة وواقف معايا" 
               class="whatsapp-btn" target="_blank" onclick="playClick()">
                💬 تواصل مع بودا 01122989039
            </a>
        </div>
    </div>

    <!-- صفحة الدرس -->
    <div id="lesson-screen" class="hidden">
        <button onclick="backToMain()" style="width: auto; padding: 10px 20px; margin-bottom: 20px;">⬅ رجوع</button>
        <div id="lesson-content"></div>
    </div>

    <script>
        // المتغيرات العامة
        let currentUser = '';
        let currentSection = 0;
        let currentLesson = 0;
        let userProgress = {};
        let labTimer;
        let timeLeft = 1800; // 30 دقيقة
        
        // الأصوات
        const clickSound = new Audio('https://www.soundjay.com/mechanical/sounds/mechanical-keyboard-1.mp3');
        const successSound = new Audio('https://www.soundjay.com/misc/sounds/bell-ringing-05.mp3');
        const failSound = new Audio('https://www.soundjay.com/misc/sounds/fail-buzzer-02.mp3');
        
        function playClick() {
            clickSound.currentTime = 0;
            clickSound.play();
        }
        
        function speak(text, pitch = 0.5) {
            const speech = new SpeechSynthesisUtterance(text);
            speech.lang = 'ar-SA';
            speech.pitch = pitch;
            speech.rate = 0.8;
            window.speechSynthesis.speak(speech);
        }
        
        // حروف اللوجو الملونة
        const logoText = "BODAELMASRY";
        const logoDiv = document.getElementById('logo');
        logoText.split('').forEach((letter, index) => {
            const span = document.createElement('span');
            span.textContent = letter;
            span.style.animationDelay = `${index * 0.1}s`;
            logoDiv.appendChild(span);
        });
        
        // الدخول
        function login() {
            playClick();
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;
            
            if (password === 'بودا المصري' && username.trim()!== '') {
                currentUser = username;
                speak(`تم التحقق.. نورت يا ${username}`);
                
                setTimeout(() => {
                    document.getElementById('login-screen').classList.add('hidden');
                    document.getElementById('main-screen').classList.remove('hidden');
                    document.getElementById('welcome-msg').textContent = `أهلاً يا هاكر ${username} 💀`;
                    loadSections();
                }, 2000);
            } else {
                document.getElementById('error').style.display = 'block';
                speak('وصول مرفوض.. حاول مرة أخرى', 0.3);
            }
        }
        
        // تحميل الأقسام
        const sections = [
            {id: 1, title: "أساسيات الهاكر - من تحت الصفر", icon: "🎯", unlocked: true},
            {id: 2, title: "الهندسة الاجتماعية - الضحك على العقول", icon: "🎭", unlocked: false},
            {id: 3, title: "اختراق الواي فاي - النت ببلاش", icon: "📶", unlocked: false},
            {id: 4, title: "اختراق الموبايل - الأندرويد ملعبك", icon: "📱", unlocked: false},
            {id: 5, title: "اختراق المواقع - بوابات السيرفر", icon: "🌐", unlocked: false},
            {id: 6, title: "اختراق السوشيال - رجع حسابك بنفسك", icon: "📘", unlocked: false},
            {id: 7, title: "التخفي - اخترق وامشي متسيبش أثر", icon: "👤", unlocked: false},
            {id: 8, title: "الشفرات - كلام المجهول السري", icon: "🔐", unlocked: false},
            {id: 9, title: "برمجة الهاكرز - اعمل أداتك بإيدك", icon: "💻", unlocked: false},
            {id: 10, title: "مشروع التخرج - شركة بودا الوهمية", icon: "🏆", unlocked: false}
        ];
        
        function loadSections() {
            const grid = document.getElementById('sections-grid');
            grid.innerHTML = '';
            
            sections.forEach(section => {
                const card = document.createElement('div');
                card.className = `section-card ${section.unlocked? '' : 'locked'}`;
                card.onclick = () => section.unlocked && openSection(section.id);
                
                card.innerHTML = `
                    <div class="section-img">${section.icon}</div>
                    <div class="section-title">القسم ${section.id}: ${section.title}</div>
                    <div>${section.unlocked? '✅ مفتوح' : '🔒 مقفول'}</div>
                `;
                grid.appendChild(card);
            });
        }
        
        // فتح القسم
        function openSection(sectionId) {
            playClick();
            currentSection = sectionId;
            currentLesson = 1;
            showLesson();
        }
        
        // عرض الدرس
        function showLesson() {
            document.getElementById('main-screen').classList.add('hidden');
            document.getElementById('lesson-screen').classList.remove('hidden');
            
            const lessonContent = document.getElementById('lesson-content');
            
            // الدرس 1.1 كمثال
            if (currentSection === 1 && currentLesson === 1) {
                lessonContent.innerHTML = `
                    <div class="lesson-content">
                        <h2>1.1 يعني ايه "عنوان الجهاز"؟</h2>
                        <p>بص يا ${currentUser}.. انت عشان تبعت جواب لصاحبك لازم تبقى عارف عنوان بيته صح؟</p>
                        <p><strong>"عنوان الجهاز"</strong> هو نفس الفكرة بالظبط بس على النت.</p>
                        <p>كل جهاز متوصل بالنت ليه "عنوان جهاز" مميز محدش شبهه.</p>
                        <p>شكله عامل ازاي؟ بيبقى 4 أرقام بينهم نقط: <code>192.168.1.1</code></p>
                        <p><strong>الهاكر بيعمل بيه ايه؟</strong><br>
                        1. يعرف انت من أنهي دولة ومدينة<br>
                        2. يعمل عليك "فحص" يشوف ايه "الأبواب المفتوحة" عندك<br>
                        3. لو لقى "باب مفتوح" = كأنه لقى شباك بيتكم مفتوح</p>
                    </div>
                    
                    <button onclick="startLab()">فهمت.. فك الشفرة 🔓</button>
                `;
            }
        }
        
        // بدء اللاب
        function startLab() {
            playClick();
            speak('تم فتح المعمل.. اختار الهدف يا بودا جونيور');
            
            const lessonContent = document.getElementById('lesson-content');
            lessonContent.innerHTML += `
                <div class="lab-section">
                    <div class="lab-title">💀 اختار الهدف اللي عايز تخترقه 💀</div>
                    <div class="lab-buttons">
                        <button class="lab-btn" onclick="startHack('هاتف')">📱 هاتف</button>
                        <button class="lab-btn" onclick="startHack('لاب')">💻 لاب</button>
                        <button class="lab-btn" onclick="startHack('واي فاي')">📶 شبكة واي فاي</button>
                        <button class="lab-btn" onclick="startHack('عنوان')">🌐 عنوان جهاز</button>
                    </div>
                    <div id="lab-terminal"></div>
                </div>
            `;
        }
        
        // بدء الاختراق
        function startHack(type) {
            playClick();
            timeLeft = 1800;
            const terminal = document.getElementById('lab-terminal');
            
            terminal.innerHTML = `
                <div class="timer" id="timer">⏱️ الوقت: 30:00</div>
                <div class="terminal" id="terminal">
                    <div style="color: #00ff00;">BODA_TERMINAL v1.0</div>
                    <div style="color: #00ff00;">الهدف: ${type} وهمي</div>
                    <div style="color: #ff0000;">المطلوب: اكتب "اختراق" وانتر</div>
                    <div style="color: #00ff00;">></div>
                </div>
                <input type="text" id="hack-input" placeholder="اكتب الأمر هنا" 
                       style="width:100%;padding:10px;background:#000;color:#00ff00;border:1px solid #00ff00;"
                       onkeypress="if(event.key==='Enter') checkHack()">
            `;
            
            // العداد
            labTimer = setInterval(() => {
                timeLeft--;
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                document.getElementById('timer').textContent = `⏱️ الوقت: ${minutes}:${seconds.toString().padStart(2, '0')}`;
                
                if (timeLeft <= 0) {
                    clearInterval(labTimer);
                    hackFailed();
                }
            }, 1000);
        }
        
        // فحص الاختراق
        function checkHack() {
            const input = document.getElementById('hack-input').value;
            const terminal = document.getElementById('terminal');
            
            if (input.includes('اختراق')) {
                clearInterval(labTimer);
                terminal.innerHTML += `<div style="color: #00ff00;">> ${input}</div>`;
                terminal.innerHTML += `<div style="color: #00ff00;">تـم اخـتـراق الـهـدف بـنـجـاح 💀</div>`;
                speak('تم اختراق الهدف بنجاح');
                successSound.play();
                
                setTimeout(() => {
                    if (currentSection === 10) {
                        showCertificate();
                    } else {
                        unlockNextSection();
                    }
                }, 3000);
            } else {
                terminal.innerHTML += `<div style="color: #ff0000;">> ${input}</div>`;
                terminal.innerHTML += `<div style="color: #ff0000;">أمر خاطئ.. حاول تاني</div>`;
            }
            document.getElementById('hack-input').value = '';
        }
        
        // فشل الاختراق
        function hackFailed() {
            failSound.play();
            speak('فشل الاختراق.. حاول مرة أخرى');
            
            const terminal = document.getElementById('lab-terminal');
            terminal.innerHTML += `
                <div style="color: #ff0000; text-align: center; padding: 20px; border: 2px solid #ff0000; margin-top: 20px;">
                    <h3>❌ فشل الاختراق ❌</h3>
                    <p>عايز محاولة تانية؟</p>
                    <p>حول 20 جنيه على 01122989039</p>
                    <button onclick="resetLab()" style="background: #00ff00; color: #000; margin-top: 10px;">
                        تم التحويل بنجاح - جرب تاني
                    </button>
                    <a href="https://wa.me/201122989039?text=حولت الـ 20 جنيه يا بودا وعايز أحاول تاني" 
                       target="_blank" style="display: block; margin-top: 10px; color: #25D366;">
                        💬 كلم بودا على الواتساب
                    </a>
                </div>
            `;
        }
        
        function resetLab() {
            playClick();
            startHack('هاتف');
        }
        
        // فتح القسم اللي بعده
        function unlockNextSection() {
            if (currentSection < 10) {
                sections[currentSection].unlocked = true;
                alert(`عاش يا ${currentUser}.. القسم ${currentSection + 1} اتفتح 🔓`);
                backToMain();
            }
        }
        
        // الشهادة
        function showCertificate() {
            const lessonContent = document.getElementById('lesson-content');
            lessonContent.innerHTML = `
                <div id="certificate">
                    <h1 style="color: #00ff00; font-size: 36px; margin-bottom: 20px;">شهادة إتمام</h1>
                    <h2 style="color: #ff0000; margin-bottom: 30px;">مدرسة بودا المصري للأمن السيبراني</h2>
                    <p style="font-size: 20px; margin: 20px 0;">تشهد بأن الهاكر</p>
                    <p style="font-size: 32px; color: #00ff00; margin: 20px 0; text-shadow: 0 0 20px #00ff00;">${currentUser}</p>
                    <p style="font-size: 18px; margin: 20px 0;">قد اجتاز 80 مهمة اختراق أخلاقي بنجاح</p>
                    <p style="margin-top: 40px;">توقيع: بودا المصري 💀</p>
                    <button onclick="downloadCertificate()" style="margin-top: 30px; width: auto; padding: 15px 40px;">
                        📱 حفظ الشهادة في المعرض
                    </button>
                </div>
            `;
            speak(`مبروك يا ${currentUser}.. انت دلوقتي هاكر معتمد من مدرسة بودا المصري`);
        }
        
        function downloadCertificate() {
            playClick();
            alert('الشهادة اتحفظت في المعرض يا وحش 📱');
        }
        
        function backToMain() {
            playClick();
            document.getElementById('lesson-screen').classList.add('hidden');
            document.getElementById('main-screen').classList.remove('hidden');
            loadSections();
        }
        
        // كل دوسة تعمل صوت
        document.addEventListener('click', playClick);
    </script>
</body>
</html>